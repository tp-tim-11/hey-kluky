# This file is read by hey_kluky/config.py (pydantic-settings)

# Required
OPENAI_API_KEY=

# Optional OpenAI-compatible base URL
# OPENAI_API_BASE=

# Optional. If set, Anthropic intent classifier is used.
# If empty, local keyword classifier is used.
# ANTHROPIC_API_KEY=

# Internal API server started by main.py
API_HOST=0.0.0.0
API_PORT=8000

# Directory sent to OpenCode as working context.
# start_all.sh requires this to be set and to exist.
TEST_OPENCODE_DIR=

# OpenCode base URL used by hey_kluky/pipeline/opencode.py
OPENCODE_URL=http://127.0.0.1:4096

# OpenCode model selection used by hey_kluky/pipeline/opencode.py
OPENCODE_PROVIDER_ID=github-copilot
OPENCODE_MODEL_ID=gpt-4.1
