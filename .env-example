# This file is read by hey_kluky/settings.py

# Required
OPENAI_API_KEY=

# Optional OpenAI-compatible base URL
# OPENAI_API_BASE=

# Optional. If set, Anthropic intent classifier is used.
# If empty, local keyword classifier is used.
# ANTHROPIC_API_KEY=

# Python API server (server.py)
HOST=127.0.0.1
PORT=8000

# Directory sent to OpenCode SDK for message execution context
# Can be overridden by start-all.sh --test-dir
TEST_OPENCODE_DIR=

# OpenCode URL consumed by opencode-sdk/index.js
# Usually set by start-all.sh
OPENCODE_URL=http://127.0.0.1:4096

# OpenCode model selection used by opencode-sdk/index.js
OPENCODE_PROVIDER_ID=github-copilot
OPENCODE_MODEL_ID=gpt-4.1

# Wakeword API target
# Usually set by start-all.sh
API_BASE_URL=http://127.0.0.1:8000
